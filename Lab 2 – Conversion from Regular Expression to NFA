#include<stdio.h>
#include<string.h>

int main()
{
    char regex[20];
    printf("Enter Regular Expression: ");
    scanf("%s",regex);

    printf("NFA construction steps:\n");

    for(int i=0;i<strlen(regex);i++)
    {
        printf("State %d -- %c --> State %d\n",i,regex[i],i+1);
    }

    printf("Final state: %d\n",strlen(regex));

    return 0;
}
