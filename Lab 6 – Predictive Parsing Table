#include<stdio.h>

int main()
{
    char table[3][3]={{'E','T',' '},
                      {'T','F',' '},
                      {'F','i',' '}};

    printf("Predictive Parsing Table\n");

    for(int i=0;i<3;i++)
    {
        for(int j=0;j<3;j++)
        {
            printf("%c ",table[i][j]);
        }
        printf("\n");
    }

    return 0;
}
